CREATE OR REPLACE VIEW v_tour_public_summary AS
    SELECT 
        t.id,
        t.code,
        t.name,
        t.slug,
        d.name AS destination_name,
        d.province,
        t.duration_days,
        t.duration_nights,
        t.base_price,
        t.currency,
        t.transport_type,
        t.trip_mode,
        t.is_student_friendly,
        t.is_family_friendly,
        t.is_senior_friendly,
        t.average_rating,
        t.total_reviews,
        t.total_bookings,
        t.status
    FROM
        tours t
            JOIN
        destinations d ON d.id = t.destination_id
