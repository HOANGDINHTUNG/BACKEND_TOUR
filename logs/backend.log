2026-04-17 21:18:31 [main] DEBUG o.f.c.i.s.DefaultSqlScriptExecutor [NO-TRACE] - Executing SQL: CREATE FUNCTION fn_generate_code(p_prefix VARCHAR(10)) 
RETURNS VARCHAR(50) DETERMINISTIC BEGIN RETURN CONCAT( 
	UPPER(p_prefix), 
    DATE_FORMAT(NOW(), '%y%m%d%H%i%s'), 
    UPPER(SUBSTRING(REPLACE(UUID(), '-', ''), 1, 6)) 
); END
