    FOREIGN KEY (combo_id) 
    REFERENCES combo_packages(id) ON DELETE SET NULL, 
    CONSTRAINT chk_booking_people CHECK ((adults + children + infants + seniors) > 0) 
) ENGINE=InnoDB
