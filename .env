# Local environment variables for BACKEND_TOUR
# Spring Boot in this repo reads OS environment variables directly.
# If your IDE/shell does not auto-load `.env`, export these vars before running the app.

# Database credentials used by `application-dev.yaml`
DB_USERNAME=wed_user
DB_PASSWORD=123456

# JWT settings used by `application.yaml` and `application-dev.yaml`
JWT_SECRET=wedservice-local-dev-secret-key-change-before-production
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=2592000000
